{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "cd backend && gunicorn server:app --bind 0.0.0.0:$PORT --workers 3 --threads 6 --timeout 120",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}