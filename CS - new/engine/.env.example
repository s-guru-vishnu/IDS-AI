# ─────────────────────────────────────────────
# IDS Engine — Environment Variables
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/IDS?retryWrites=true&w=majority

# Backend API URL (Render deployment)
BACKEND_URL=https://cybermatrix-api.onrender.com

# Engine identity (unique per EC2 instance)
ENGINE_NAME=ids-engine-01

# Environment: production | staging | development
ENVIRONMENT=production

# Groq API key for XAI explanations (optional)
GROQ_API_KEY=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Network interface to sniff (leave empty for all interfaces)
# Examples: eth0, ens5, wlan0
NETWORK_INTERFACE=

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=30
